{
  "name": "runvie-contracts",
  "version": "0.1.0",
  "private": true,
  "description": "OpenAPI specs + contract test runner for RunVie",
  "scripts": {
    "test": "jest",
    "lint:ai": "redocly lint ai-coach-openapi.yaml",
    "lint:edge": "redocly lint edge-functions-openapi.yaml",
    "postman:ai": "openapi2postmanv2 -s ai-coach-openapi.yaml -o ai-coach.postman_collection.json -p",
    "postman:edge": "openapi2postmanv2 -s edge-functions-openapi.yaml -o edge-functions.postman_collection.json -p"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.0",
    "openapi-to-postmanv2": "^4.21.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
