  "semantic": {
    "brand": {
      "primary":   "{primitive.coral.500}",
      "secondary": "{primitive.mint.500}",
      "tertiary":  "{primitive.lavender.500}",
      "gradientStart":  "#FF5A36",
      "gradientMiddle": "#7B5CFF",
      "gradientEnd":    "#00D4A8"
    },
    "accent": {
      "energy":   "{primitive.coral.500}",
      "recovery": "{primitive.mint.500}",
      "focus":    "{primitive.lavender.500}"
    },
    "feedback": {
      "success": "{primitive.mint.500}",
      "warning": "{primitive.zone.z2}",
      "danger":  "{primitive.zone.z4}",
      "info":    "{primitive.lavender.500}"
    },
    "hrZone": {
      "z1": { "value": "{primitive.zone.z1}", "label": "Recovery" },
      "z2": { "value": "{primitive.zone.z2}", "label": "Aerobic" },
      "z3": { "value": "{primitive.zone.z3}", "label": "Tempo" },
      "z4": { "value": "{primitive.zone.z4}", "label": "Threshold" },
      "z5": { "value": "{primitive.zone.z5}", "label": "Max" }
    },
    "bg": {
