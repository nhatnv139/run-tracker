      "strong":   "{primitive.neutral.300}",
      "focus":    "{primitive.coral.500}",
      "inverse":  "{primitive.neutral.700}"
    }
  },
  "darkMode": {
    "bg": {
      "canvas":   "{primitive.neutral.950}",
      "surface":  "{primitive.neutral.850}",
      "elevated": "{primitive.neutral.800}",
      "muted":    "{primitive.neutral.700}"
    },
    "text": {
      "primary":   "{primitive.neutral.50}",
      "secondary": "{primitive.neutral.300}",
      "muted":     "{primitive.neutral.400}"
    },
    "border": {
      "subtle":  "{primitive.neutral.800}",
      "default": "{primitive.neutral.700}",
      "strong":  "{primitive.neutral.600}"
