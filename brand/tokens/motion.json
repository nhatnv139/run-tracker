{
  "$schema": "runvie-design-tokens-v1",
  "description": "Motion tokens. RunVie motion is light, springy, and confident. Never over 400ms for UI transitions.",
  "duration": {
    "instant": "0ms",
    "fast":    "150ms",
    "base":    "250ms",
    "slow":    "400ms",
    "celebrate": "600ms"
  },
  "easing": {
    "linear":     "cubic-bezier(0, 0, 1, 1)",
    "standard":   "cubic-bezier(0.2, 0, 0, 1)",
    "emphasized": "cubic-bezier(0.3, 0, 0, 1)",
    "decelerate": "cubic-bezier(0, 0, 0, 1)",
    "accelerate": "cubic-bezier(0.3, 0, 1, 1)",
    "spring":     "cubic-bezier(0.34, 1.56, 0.64, 1)",
    "bounce":     "cubic-bezier(0.68, -0.55, 0.27, 1.55)"
  },
  "presets": {
    "fade":           { "duration": "{duration.base}", "easing": "{easing.standard}" },
    "slide":          { "duration": "{duration.base}", "easing": "{easing.emphasized}" },
    "pop":            { "duration": "{duration.fast}", "easing": "{easing.spring}" },
    "modalEnter":     { "duration": "{duration.slow}", "easing": "{easing.decelerate}" },
    "modalExit":      { "duration": "{duration.base}", "easing": "{easing.accelerate}" },
    "celebrateBurst": { "duration": "{duration.celebrate}", "easing": "{easing.bounce}" }
  }
}
