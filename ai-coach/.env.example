# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
MODEL_SONNET=claude-sonnet-4-7
MODEL_HAIKU=claude-haiku-4-5-20251001
MAX_TOKENS_DEFAULT=1024
ENABLE_CACHE=true

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CHAT_TTL_SECONDS=86400
REDIS_CHAT_WINDOW=20

# Sentry (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

# Rate limits
RATE_LIMIT_FREE_PER_MONTH=20
RATE_LIMIT_PAID_PER_DAY=100

# Supabase auth (set AUTH_REQUIRED=true in prod)
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
AUTH_REQUIRED=false
